<Window x:Class="UfanetApp.AddEditEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сотрудник" Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#E3F2FD"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="tbTitle" Text="Добавление сотрудника" FontSize="18" FontWeight="Bold" 
                   Foreground="#1976D2" Grid.Row="0" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <TextBlock Text="Фамилия:" Grid.Row="1" Margin="0,5" Foreground="#333333"/>
        <TextBox x:Name="tbLastName" Grid.Row="2" Height="35" Margin="0,0,0,10"/>

        <TextBlock Text="Имя:" Grid.Row="3" Margin="0,5" Foreground="#333333"/>
        <TextBox x:Name="tbFirstName" Grid.Row="4" Height="35" Margin="0,0,0,10"/>

        <TextBlock Text="Отчество:" Grid.Row="5" Margin="0,5" Foreground="#333333"/>
        <TextBox x:Name="tbPatronymic" Grid.Row="6" Height="35" Margin="0,0,0,10"/>

        <TextBlock Text="Должность:" Grid.Row="7" Margin="0,5" Foreground="#333333"/>
        <TextBox x:Name="tbPosition" Grid.Row="8" Height="35" Margin="0,0,0,10"/>

        <TextBlock Text="Отдел:" Grid.Row="9" Margin="0,5" Foreground="#333333"/>
        <TextBox x:Name="tbDepartment" Grid.Row="10" Height="35" Margin="0,0,0,10"/>

        <TextBlock Text="Телефон:" Grid.Row="11" Margin="0,5" Foreground="#333333"/>
        <TextBox x:Name="tbPhone" Grid.Row="12" Height="35" Margin="0,0,0,10"/>

        <TextBlock Text="Email:" Grid.Row="13" Margin="0,5" Foreground="#333333"/>
        <TextBox x:Name="tbEmail" Grid.Row="14" Height="35" Margin="0,0,0,10"/>

        <TextBlock Text="Зарплата:" Grid.Row="15" Margin="0,5" Foreground="#333333"/>
        <TextBox x:Name="tbSalary" Grid.Row="16" Height="35" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="17" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnSave" Content="СОХРАНИТЬ" Width="110" Height="40" 
                    Margin="0,0,15,0" Click="btnSave_Click"
                    Background="#66BB6A" Foreground="White" FontWeight="Bold" FontSize="13"/>
            <Button x:Name="btnCancel" Content="ОТМЕНА" Width="110" Height="40" 
                    Click="btnCancel_Click"
                    Background="#EF5350" Foreground="White" FontWeight="Bold" FontSize="13"/>
        </StackPanel>
    </Grid>
</Window>