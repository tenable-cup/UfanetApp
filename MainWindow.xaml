<Window x:Class="UfanetApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Уфанет" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#E3F2FD"
        WindowStyle="None" AllowsTransparency="True">

    <Border Background="#E3F2FD" CornerRadius="20" BorderBrush="#1976D2" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button x:Name="btnClose" Content="✖" Width="35" Height="35" 
                    HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Margin="0,10,15,0" Click="btnClose_Click"
                    Background="Transparent" Foreground="#1976D2" 
                    FontSize="14" FontWeight="Bold" BorderThickness="0"
                    Cursor="Hand"/>

            <Border Grid.Row="0" Background="#1976D2" Padding="20" CornerRadius="20,20,0,0">
                <StackPanel>
                    <TextBlock Text="УФАНЕТ" FontSize="28" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Интернет-провайдер" FontSize="14" 
                               Foreground="#BBDEFB" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button x:Name="btnOpenEmployees" Content="СОТРУДНИКИ" 
                        Width="250" Height="65" Click="btnOpenEmployees_Click"
                        Background="#42A5F5" Foreground="White" FontWeight="Bold" FontSize="16"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="35" BorderBrush="#1565C0" BorderThickness="2">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1E88E5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <Border Grid.Row="2" Background="#1976D2" Padding="12" CornerRadius="0,0,20,20">
                <TextBlock Text="© 2024 Уфанет - Все права защищены" 
                           Foreground="#BBDEFB" FontSize="11" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>